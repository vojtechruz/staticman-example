---
layout: layout.njk
title: Static comments by Staticman
---

{% set sortedComments = comments | getSortedComments %}

<section class="comment-form-container">
    <h2>Leave a comment</h2>
    <form method="POST" action="https://api.staticman.net/v2/entry/vojtechruz/staticman-example/master/comments">
        <input name="options[redirect]" type="hidden" value="https://staticman-example.netlify.com/"/>

        <div class="form-group">
            <label for="name">Name</label>
            <input id="name" name="fields[name]" type="text" required placeholder="Your name">
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input id="email" name="fields[email]" type="email" required placeholder="your.email@example.com">
        </div>

        <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="fields[message]" required placeholder="What's on your mind?"></textarea>
        </div>

        <button type="submit">Post Comment</button>
    </form>
</section>

<h2>Latest comments</h2>

<div class="comments-list">
    {% for comment in sortedComments %}
    <article class="comment">
        <header class="comment-header">
            <span class="name">{{ comment.name }}</span>
            <span class="date">{{ comment.date | date }}</span>
        </header>
        <p class="comment-body">{{ comment.message }}</p>
    </article>
    {% endfor %}
</div>

